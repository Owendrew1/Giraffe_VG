# Giraffe mapping on cactus pangenome graphs.
# Run from repo root:
#   ./scripts/run_giraffe.sh 4
# Setup: conda env create -f environment.yaml  (Snakemake only; vg runs in conda per rule)

configfile: "../config/config.yaml"
include: "rules/common.smk"


rule all:
    input:
        DONE,


rule giraffe_index:
    input:
        pangenome_done=PANGENOME_DONE,
        index_done=INDEX_DONE,
        gbz=lambda wc: graph_input(wc, "gbz"),
        dist=lambda wc: graph_input(wc, "dist"),
        min=lambda wc: graph_input(wc, "min"),
    output:
        gbz=f"{RES}/{{graph_id}}/index/graph.gbz",
        dist=f"{RES}/{{graph_id}}/index/graph.dist",
        min=f"{RES}/{{graph_id}}/index/graph.min",
        done=f"{RES}/{{graph_id}}/index/index.done",
    log:
        f"{LOG}/giraffe_index/{{graph_id}}.log",
    params:
        outdir=index_out,
    threads:
        CORES,
    conda:
        CONDA,
    shell:
        """
        set -euo pipefail
        exec > >(tee -a {log}) 2>&1
        mkdir -p {params.outdir}
        resolve_or_rebuild() {{
          local path="$1" kind="$2"
          if [[ -e "$path" ]]; then echo "$path"; return; fi
          local rebuilt="{PGD}/$(basename "$path")"
          if [[ "$kind" == min ]]; then
            vg minifier -t {threads} -d 10 -o "$rebuilt" {input.gbz}
          else
            vg distance -t {threads} -o "$rebuilt" {input.gbz}
          fi
          echo "$rebuilt"
        }}
        ln -sf {input.gbz} {params.outdir}/graph.gbz
        ln -sf "$(resolve_or_rebuild {input.dist} dist)" {params.outdir}/graph.dist
        ln -sf "$(resolve_or_rebuild '{input.min}' min)" {params.outdir}/graph.min
        touch {params.outdir}/index.done
        """


rule giraffe_sample:
    input:
        gbz=rules.giraffe_index.output.gbz,
        dist=rules.giraffe_index.output.dist,
        min=rules.giraffe_index.output.min,
        r1=lambda wc: fastq_path(sample_row(wc), "r1"),
        r2=lambda wc: fastq_path(sample_row(wc), "r2"),
        ref=ref_path_for_graph,
        ref_fai=lambda wc: ref_path_for_graph(wc) + ".fai",
    output:
        gam=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.gam",
        bam=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.surject.bam",
        bai=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.surject.bam.bai",
    log:
        f"{LOG}/giraffe_sample/{{graph_id}}_{{sample_id}}.log",
    params:
        outdir=sample_out,
        read_group=surject_read_group,
    threads:
        CORES,
    resources:
        mem_mb=MEM_MB,
    conda:
        CONDA,
    shell:
        """
        set -euo pipefail
        exec > >(tee -a {log}) 2>&1
        mkdir -p {params.outdir}
        vg giraffe -Z {input.gbz} -d {input.dist} -m {input.min} \\
          -f {input.r1} -f {input.r2} -t {threads} > '{output.gam}'
        vg surject -t {threads} -i '{output.gam}' -x {input.ref} -b '{output.bam}' -R "{params.read_group}"
        samtools index -@ {threads} '{output.bam}'
        """


rule qc_flagstat:
    input:
        bam=rules.giraffe_sample.output.bam,
        bai=rules.giraffe_sample.output.bai,
    output:
        f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.flagstat.txt",
    log:
        f"{LOG}/qc_flagstat/{{graph_id}}_{{sample_id}}.log",
    conda:
        CONDA,
    shell:
        "samtools flagstat {input.bam} > {output} 2> {log}"


rule qc_vg_stats:
    input:
        gbz=rules.giraffe_index.output.gbz,
        gam=rules.giraffe_sample.output.gam,
    output:
        f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.vg_stats.txt",
    log:
        f"{LOG}/qc_vg_stats/{{graph_id}}_{{sample_id}}.log",
    conda:
        CONDA,
    shell:
        "vg stats -z {input.gbz} -a '{input.gam}' > {output} 2> {log}"


rule vg_variant_call:
    input:
        gbz=rules.giraffe_index.output.gbz,
        gam=rules.giraffe_sample.output.gam,
        ref=ref_path_for_graph,
    output:
        vcf=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.vg_call.vcf.gz",
        tbi=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.vg_call.vcf.gz.tbi",
    log:
        f"{LOG}/vg_variant_call/{{graph_id}}_{{sample_id}}.log",
    threads:
        CORES,
    conda:
        CONDA,
    shell:
        """
        set -euo pipefail
        exec > >(tee -a {log}) 2>&1
        WRK=$(mktemp -d)
        trap 'rm -rf "$WRK"' EXIT
        vg snarls {input.gbz} > "$WRK/snarls.snarls"
        vg pack -x {input.gbz} -g '{input.gam}' -o "$WRK/pack.gz" -t {threads}
        vg call "$WRK/pack.gz" -k "$WRK/snarls.snarls" -a -r {input.ref} -t {threads} \\
          | bgzip -c > {output.vcf}
        tabix -f -p vcf {output.vcf}
        """


rule small_variant_call:
    input:
        bam=rules.giraffe_sample.output.bam,
        bai=rules.giraffe_sample.output.bai,
        ref=ref_path_for_graph,
    output:
        vcf=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.small_variants.vcf.gz",
        tbi=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.small_variants.vcf.gz.tbi",
    log:
        f"{LOG}/small_variant_call/{{graph_id}}_{{sample_id}}.log",
    params:
        sample=lambda wc: wc.sample_id,
    threads:
        CORES,
    conda:
        CONDA,
    shell:
        """
        set -euo pipefail
        gatk HaplotypeCaller \\
          -R {input.ref} \\
          -I {input.bam} \\
          -O {output.vcf} \\
          --sample-name {params.sample} \\
          --native-pair-hmm-threads {threads} \\
          2> {log}
        tabix -f -p vcf {output.vcf}
        """


rule sv_regions:
    input:
        bam=rules.giraffe_sample.output.bam,
        small_vcf=rules.small_variant_call.output.vcf,
        vg_vcf=rules.vg_variant_call.output.vcf,
    output:
        tsv=f"{RES}/{{graph_id}}/{{sample_id}}/{{sample_id}}.sv_regions.tsv",
    log:
        f"{LOG}/sv_regions/{{graph_id}}_{{sample_id}}.log",
    params:
        outdir=regions_out,
    conda:
        CONDA,
    shell:
        """
        set -euo pipefail
        exec > >(tee -a {log}) 2>&1
        mkdir -p {params.outdir} $(dirname {output.tsv})
        echo -e "region_id\\tchrom\\tstart\\tend\\tmean_depth\\tmapped_reads\\tmean_mapq\\tsmall_variant_count\\tvg_call_variant_count" > {output.tsv}
        while IFS= read -r line || [[ -n "$line" ]]; do
          [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
          [[ "$line" =~ ^([^:]+):([0-9]+)-([0-9]+)$ ]] || {{ echo "Bad region: $line" >&2; exit 1; }}
          chrom="${{BASH_REMATCH[1]}}"
          start="${{BASH_REMATCH[2]}}"
          end="${{BASH_REMATCH[3]}}"
          coords="${{chrom}}:${{start}}-${{end}}"
          region_id="${{chrom}}_${{start}}_${{end}}"
          region_id="${{region_id//./_}}"
          locus_dir="{params.outdir}/$region_id"
          mkdir -p "$locus_dir"
          samtools view -b -r "$coords" -o "$locus_dir/$region_id.bam" {input.bam}
          bcftools view -r "$coords" -Oz -o "$locus_dir/$region_id.small_variants.vcf.gz" {input.small_vcf}
          bcftools view -r "$coords" -Oz -o "$locus_dir/$region_id.vg_call.vcf.gz" {input.vg_vcf}
          mean_depth="$(samtools depth -r "$coords" {input.bam} | awk '{{s+=$3;n++}} END {{if(n>0) printf "%.2f", s/n; else print "0"}}')"
          mapped_reads="$(samtools view -c -r "$coords" {input.bam})"
          mean_mapq="$(samtools view -r "$coords" {input.bam} | awk '{{s+=$5;n++}} END {{if(n>0) printf "%.2f", s/n; else print "0"}}')"
          small_n="$(bcftools view -H -r "$coords" "$locus_dir/$region_id.small_variants.vcf.gz" | wc -l | tr -d ' ')"
          vg_n="$(bcftools view -H -r "$coords" "$locus_dir/$region_id.vg_call.vcf.gz" | wc -l | tr -d ' ')"
          echo -e "${{region_id}}\\t${{chrom}}\\t${{start}}\\t${{end}}\\t${{mean_depth}}\\t${{mapped_reads}}\\t${{mean_mapq}}\\t${{small_n}}\\t${{vg_n}}" >> {output.tsv}
        done < {REGIONS_FILE}
        """


rule giraffe_done:
    input:
        done_inputs,
    output:
        DONE,
    shell:
        "touch {output}"
